# Ramparts Proxy Configuration Example
# Copy this file and customize for your deployment

# =============================================================================
# REQUIRED: API KEY CONFIGURATION
# =============================================================================

# Javelin API key (required for proxy functionality)
# Obtain from: https://www.getjavelin.com
JAVELIN_API_KEY="your-javelin-api-key-here"

# Alternative API key environment variables (for compatibility)
# LLM_API_KEY="your-api-key-here"
# OPENAI_API_KEY="your-openai-api-key-here"

# =============================================================================
# JAVELIN API CONFIGURATION
# =============================================================================

# Javelin API base URL (default: https://api.getjavelin.com)
JAVELIN_API_URL="https://api.getjavelin.com"

# Request timeout for Javelin API calls in seconds (default: 30)
JAVELIN_TIMEOUT_SECONDS="30"

# Fail strategy when Javelin API is unavailable
# true = fail open (allow requests), false = fail closed (deny requests)
# Default: true (for better availability)
JAVELIN_FAIL_OPEN="true"

# =============================================================================
# PROXY SERVER CONFIGURATION
# =============================================================================

# Listen address for the proxy server (default: 127.0.0.1:8080)
PROXY_LISTEN_ADDRESS="127.0.0.1:8080"

# Enable request/response logging (default: true)
PROXY_LOG_REQUESTS="true"

# Enable validation result caching (default: false for security)
PROXY_CACHE_VALIDATIONS="false"

# Cache TTL in seconds when caching is enabled (default: 300)
PROXY_CACHE_TTL_SECONDS="300"

# Maximum request size in bytes (default: 1MB)
PROXY_MAX_REQUEST_SIZE="1048576"

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================

# Rust log level (error, warn, info, debug, trace)
RUST_LOG="info"

# Enable JSON structured logging
# RUST_LOG_JSON="true"

# =============================================================================
# DEPLOYMENT EXAMPLES
# =============================================================================

# Development
# PROXY_LISTEN_ADDRESS="127.0.0.1:8080"
# RUST_LOG="debug"

# Production
# PROXY_LISTEN_ADDRESS="0.0.0.0:8080"
# RUST_LOG="info"
# JAVELIN_FAIL_OPEN="false"

# High Performance
# PROXY_CACHE_VALIDATIONS="true"
# PROXY_CACHE_TTL_SECONDS="60"
# JAVELIN_TIMEOUT_SECONDS="10"
